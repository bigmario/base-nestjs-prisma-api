# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Force shell scripts to always use LF (critical for Docker/Linux)
*.sh text eol=lf

# Force batch files to use CRLF (Windows only)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.hbs binary
